# Copy to .env on the server and edit values

# Bind port — keep 4000 unless your VPS demands otherwise
PORT=4000

# production | development
NODE_ENV=production

# Comma-separated list of front-end origins allowed to call the API
ALLOWED_ORIGINS=https://www.globalshorefinservices.com,http://www.globalshorefinservices.com,https://globalshorefinservices.com,http://globalshorefinservices.com,https://global-shore-fin-edge.vercel.app,http://localhost:4000,http://localhost:5173

# Set to true to expose /docs and /openapi.json in production (off by default)
EXPOSE_DOCS=true

# Admin credentials — REQUIRED in production (no hardcoded fallbacks)
ADMIN_USER=admin
ADMIN_PASS=admin123
JWT_SECRET=naveen_secret_key
